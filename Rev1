                { type: 'bar', label: 'Dynamic Gross Rev', data: data.map(d => d.revenue), backgroundColor: 'rgba(79, 70, 229, 0.8)', borderRadius: 4 },
                { type: 'line', label: 'Dynamic Expenses', data: data.map(d => d.expenses), borderColor: '#DC2626', borderWidth: 3, pointRadius: 0, tension: 0.1 }
            ]
        };
        chart1.update();

        // Chart 2: Cumulative
        chart2.data = {
            labels: labels,
            datasets: [
                { label: 'Zero Line', data: data.map(() => 0), borderColor: '#94A3B8', borderWidth: 1, borderDash: [3, 3], pointRadius: 0, fill: false },
                { label: 'Base Case Net Cash (PBT)', data: data.map(d => d.baseCumulative), borderColor: '#34D399', borderWidth: 2, borderDash: [5, 5], pointRadius: 0, fill: false, tension: 0.4 },
                { label: 'Dynamic Net Cash (PBT)', data: data.map(d => d.cumulative), borderColor: '#10B981', backgroundColor: 'rgba(16, 185, 129, 0.1)', borderWidth: 3, pointRadius: 0, fill: true, tension: 0.4 }
            ]
        };
        chart2.update();

        // Chart 3: Enrollment
        chart3.data = {
            labels: labels,
            datasets: [
                { label: 'Dynamic Max Capacity', data: data.map(() => state.maxCapacity), borderColor: '#F59E0B', borderWidth: 2, borderDash: [5, 5], pointRadius: 0, stepped: true },
                { label: 'Base Case Students', data: data.map(d => d.baseStudents), borderColor: '#60A5FA', borderWidth: 2, borderDash: [5, 5], pointRadius: 0, tension: 0.4 },
                { label: 'Dynamic Students', data: data.map(d => d.students), borderColor: '#3B82F6', backgroundColor: 'rgba(59, 130, 246, 0.15)', borderWidth: 3, pointRadius: 0, fill: true, tension: 0.4 }
            ]
        };
        chart3.options.scales.y.max = state.maxCapacity * 1.2;
        chart3.update();
    }

    // --- FILE UPLOAD PARSER ---
    async function handleFileUpload(e) {
        const file = e.target.files[0];
        if (!file) return;
        
        const btn = document.getElementById('uploadBtn');
        btn.innerText = 'Processing...';
        btn.disabled = true;

        try {
            const reader = new FileReader();
            
            reader.onload = (event) => {
                try {
                    const data = new Uint8Array(event.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });
                    
                    const sheetName = workbook.SheetNames.includes('Sridhars FINAL Workings') ? 'Sridhars FINAL Workings' : workbook.SheetNames[0];
                    const worksheet = workbook.Sheets[sheetName];
                    const csvText = XLSX.utils.sheet_to_csv(worksheet);
                    const lines = csvText.split(/\r?\n/);
                    
                    let headerIdx = -1;
                    for (let i = 0; i < Math.min(20, lines.length); i++) {
                        const lowerLine = lines[i].toLowerCase();
                        if ((lowerLine.includes("pre school") || lowerLine.includes("total enrolments")) && lowerLine.includes("expenses")) { 
                            headerIdx = i; 
                            break; 
                        }
                    }
                    if (headerIdx === -1) { 
                        alert("Could not find required columns ('Pre School', 'Expenses'). Check your Excel file."); 
                        resetUploadBtn(btn, e); return; 
                    }

                    const headers = lines[headerIdx].split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/).map(h => h.replace(/^"|"$/g, '').trim());
                    
                    const colMap = {
                        year: headers.findIndex(h => { const l = h.toLowerCase(); return l.includes('years') || l === 'year' || l.includes('year '); }),
                        pre: headers.findIndex(h => { const l = h.toLowerCase(); return (l.includes('pre school') && !l.includes('fee')) || l === 'pre school'; }),
                        after: headers.findIndex(h => { const l = h.toLowerCase(); return (l.includes('after school') && !l.includes('fee')) || l === 'after school'; }),
                        expenses: headers.findIndex(h => { const l = h.toLowerCase(); return l.includes('total expenses'); })
                    };

                    let parsedData = [];
                    for (let i = headerIdx + 1; i < lines.length; i++) {
                        if (!lines[i].trim()) continue;
                        const row = lines[i].split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/).map(val => val ? val.replace(/^"|"$/g, '').trim() : '');
                        
                        if (row.length <= Math.max(colMap.pre, colMap.expenses)) continue;

                        let yearMatch = (row[colMap.year] || "").match(/\d+/);
                        if (!yearMatch) continue;
                        let yearVal = parseInt(yearMatch[0]);
                        if (yearVal > 30) continue;

                        let pre = parseFloat((row[colMap.pre] || '').replace(/,/g, '')) || 0;
                        let after = parseFloat((row[colMap.after] || '').replace(/,/g, '')) || 0;
                        let exp = parseFloat((row[colMap.expenses] || '').replace(/,/g, '')) || 0;

                        parsedData.push({
                            yearNum: yearVal,
                            preStudents: Math.round(pre),
                            afterStudents: Math.round(after),
                            baseExpenses: Math.round(exp)
                        });
                    }

                    while (parsedData.length < 30) {
                        let last = parsedData.length > 0 ? parsedData[parsedData.length - 1] : { yearNum: 0, preStudents:0, afterStudents:0, baseExpenses:0 };
                        parsedData.push({ ...last, yearNum: last.yearNum + 1 });
                    }

                    baseCaseData = parsedData.slice(0, 30);
                    alert(`Base Case successfully loaded from sheet: ${sheetName}! Review numbers using the Edit button.`);
                    fetchData(); // Recalculate everything with new base case
                } catch (err) {
                    console.error(err);
                    alert("Error parsing the Excel file. Check browser console for details.");
                } finally {
                    resetUploadBtn(btn, e);
                }
            };
            reader.readAsArrayBuffer(file);
        } catch (error) {
            alert("Failed to load Excel parsing engine. Please check your internet connection.");
            resetUploadBtn(btn, e);
        }
    }

    function resetUploadBtn(btn, e) {
        btn.innerText = 'Upload File';
        btn.disabled = false;
        e.target.value = '';
    }
</script>
