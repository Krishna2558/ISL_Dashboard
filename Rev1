    // --- INPUT HANDLERS ---
    function handleTextChange(name, val, min, max) {
        let rawStr = val.replace(/[^0-9.]/g, '');
        const parts = rawStr.split('.');
        if (parts.length > 2) rawStr = parts[0] + '.' + parts.slice(1).join('');
        
        let txtEl = document.getElementById(`txt_${name}`);
        let errEl = document.getElementById(`err_${name}`);
        let rngEl = document.getElementById(`rng_${name}`);

        let finalString = rawStr === '' ? '' : (rawStr.endsWith('.') ? Number(parts[0]).toLocaleString('en-IN') + '.' : (parts.length === 2 ? Number(parts[0]).toLocaleString('en-IN') + '.' + parts[1] : Number(rawStr).toLocaleString('en-IN')));
        
        // Preserve cursor position roughly
        let oldLength = txtEl.value.length;
        let cursorStart = txtEl.selectionStart;
        txtEl.value = finalString;
        let diff = finalString.length - oldLength;
        txtEl.setSelectionRange(cursorStart + diff, cursorStart + diff);
        
        errEl.classList.add('hidden');
        txtEl.classList.remove('border-red-500', 'bg-red-50', 'text-red-700', 'focus:ring-red-500');
        txtEl.classList.add('border-gray-300', 'focus:ring-indigo-500', 'focus:border-indigo-500');

        if (rawStr === '') { showError(name, 'Required'); return; }
        let parsedVal = parseFloat(rawStr);
        if (isNaN(parsedVal)) { showError(name, 'Invalid'); return; }
        if (parsedVal < min) { showError(name, `Min ${min.toLocaleString('en-IN')}`); return; }
        if (parsedVal > max) { showError(name, `Max ${max.toLocaleString('en-IN')}`); return; }

        state[name] = parsedVal;
        rngEl.value = parsedVal;
        fetchData();
    }

    function handleSliderChange(name, val) {
        let parsedVal = parseFloat(val);
        state[name] = parsedVal;
        
        let txtEl = document.getElementById(`txt_${name}`);
        let errEl = document.getElementById(`err_${name}`);
        
        txtEl.value = parsedVal.toLocaleString('en-IN', { maximumFractionDigits: 2 });
        errEl.classList.add('hidden');
        txtEl.classList.remove('border-red-500', 'bg-red-50', 'text-red-700', 'focus:ring-red-500');
        txtEl.classList.add('border-gray-300', 'focus:ring-indigo-500', 'focus:border-indigo-500');
        
        fetchData();
    }

    function showError(name, msg) {
        let txtEl = document.getElementById(`txt_${name}`);
        let errEl = document.getElementById(`err_${name}`);
        errEl.innerText = msg;
        errEl.classList.remove('hidden');
        txtEl.classList.remove('border-gray-300', 'focus:ring-indigo-500', 'focus:border-indigo-500');
        txtEl.classList.add('border-red-500', 'bg-red-50', 'text-red-700', 'focus:ring-red-500');
    }

