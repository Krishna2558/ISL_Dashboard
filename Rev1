<script>
    // --- FIXED PROJECT PARAMETERS ---
    const FIXED_CAPEX = 200000000; // 20 Crores fixed Initial Investment
    const TOTAL_SHARES = 100;
    const PRICE_PER_SHARE = FIXED_CAPEX / TOTAL_SHARES; // 20 Lakhs
    const MINIMUM_GUARANTEE_RATE = 0.06; // 6%
    const MINIMUM_GUARANTEE_PAYOUT = PRICE_PER_SHARE * MINIMUM_GUARANTEE_RATE; // 1.2 Lakhs per year

    // --- HELPER FUNCTIONS ---
    function calculateIRR(cf) {
        let sum = cf.reduce((a, b) => a + b, 0);
        let guess = sum < 0 ? -0.1 : 0.1; 
        for (let i = 0; i < 1000; i++) {
            let npvGuess = 0;
            let dNpv = 0;
            for (let t = 0; t < cf.length; t++) {
                npvGuess += cf[t] / Math.pow(1 + guess, t);
                if (t > 0) dNpv -= t * cf[t] / Math.pow(1 + guess, t + 1);
            }
            if (Math.abs(npvGuess) < 0.0001) return guess * 100;
            let nextGuess = guess - npvGuess / dNpv;
            if (Math.abs(nextGuess - guess) < 0.00001) return nextGuess * 100;
            guess = nextGuess;
        }
        return null;
    }

    // --- STATE & CONFIG ---
    let chart1, chart2, chart3;
    let baseCaseData = [];
    
    // Generate Initial Base Data based on Sridhar's initial points
    for(let i=1; i<=30; i++) {
        let progress = (i - 1) / 27; 
        if (progress > 1) progress = 1;
        
        let pre = 77 + (360 - 77) * progress; 
        let after = 19.25 + (150 - 19.25) * progress; 
        let exp = 38500000 + (207942158 - 38500000) * progress;
        
        baseCaseData.push({
            yearNum: i,
            preStudents: Math.round(pre),
            afterStudents: Math.round(after),
            baseExpenses: Math.round(exp)
        });
    }

    const inputConfig = [
        { label: "Discount Rate (For NPV)", name: "discountRate", min: 0, max: 100, step: 0.5, symbol: "%", value: 8 },
        { type: "divider" },
        { type: "header", label: "Enrollment & Revenue", icon: "users" },
        { label: "Start Pre-School Students", name: "startingPreStudents", min: 0, max: 500, step: 1, value: 77 },
        { label: "Start After-School Students", name: "startingAfterStudents", min: 0, max: 500, step: 1, value: 19 },
        { label: "Annual Student Growth", name: "studentGrowth", min: 0, max: 100, step: 1, symbol: "%", value: 6 },
        { label: "Maximum Capacity", name: "maxCapacity", min: 50, max: 2000, step: 10, value: 550 },
        { label: "Pre-School Fee (Yr 1)", name: "preSchoolFee", min: 10000, max: 1000000, step: 5000, symbol: "₹", value: 160000 },
        { label: "After-School Fee (Yr 1)", name: "afterSchoolFee", min: 10000, max: 1000000, step: 5000, symbol: "₹", value: 60000 },
        { label: "Annual Fee Growth", name: "feeGrowth", min: 0, max: 100, step: 0.5, symbol: "%", value: 5 },
        { type: "divider" },
        { type: "header", label: "Operating Expenses", icon: "activity" },
        { label: "Fixed Annual Costs", name: "fixedCosts", min: 1000000, max: 100000000, step: 500000, symbol: "₹", value: 38000000 },
        { label: "Variable Cost (Per Student)", name: "variableCostPerStudent", min: 5000, max: 500000, step: 1000, symbol: "₹", value: 15000 },
        { label: "Annual Expense Growth", name: "expenseGrowth", min: 0, max: 100, step: 0.5, symbol: "%", value: 6 }
    ];

    let state = {};
    inputConfig.forEach(c => { if(c.name) state[c.name] = c.value; });

    // --- INITIALIZATION ---
    document.addEventListener("DOMContentLoaded", () => {
        lucide.createIcons();
        renderInputs();
        initCharts();
        fetchData();
    });

    // --- FORMATTERS ---
    const formatCurr = (val) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(val || 0);
    const formatNum = (val) => new Intl.NumberFormat('en-IN', { maximumFractionDigits: 1 }).format(val || 0);
    const formatMoic = (val) => val.toFixed(2) + 'x';
    const formatIrrTxt = (val) => val === null ? 'N/A' : (val < 0 ? 'Negative' : `${formatNum(val)}%`);

    // --- UI RENDERING ---
    function renderInputs() {
        const container = document.getElementById('inputs-container');
        let html = '';

        inputConfig.forEach(config => {
            if (config.type === 'divider') {
                html += `<div class="w-full h-px bg-gray-200 my-6"></div>`;
            } else if (config.type === 'header') {
                html += `<div class="flex items-center space-x-2 mb-4 text-indigo-700">
