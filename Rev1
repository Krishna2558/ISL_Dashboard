    // --- FINANCIAL ENGINE ---
    function fetchData() {
        let inputs = state;
        let investorYear = parseInt(document.getElementById('inp_investorYear').value);

        let projectionData = [];
        
        // Dynamic Tracking Variables
        let currentPre = inputs.startingPreStudents;
        let currentAfter = inputs.startingAfterStudents;
        let currentPreFee = inputs.preSchoolFee;
        let currentAfterFee = inputs.afterSchoolFee;
        let currentFixedCost = inputs.fixedCosts;
        let currentVarCost = inputs.variableCostPerStudent;
        
        let cumulativeCashFlow = -FIXED_CAPEX;
        let cashFlows = [-FIXED_CAPEX];
        let investorCashFlows = [-PRICE_PER_SHARE];
        let paybackYear = null;
        let investorPaybackYear = null;
        let totalNetProfit = 0;
        let totalInvestorPayout = 0;

        // Base Case Tracking Variables
        let bCumulativeCashFlow = -FIXED_CAPEX;
        let bCashFlows = [-FIXED_CAPEX];
        let bInvestorCashFlows = [-PRICE_PER_SHARE];
        let bPaybackYear = null;
        let bInvestorPaybackYear = null;
        let bTotalNetProfit = 0;
        let bTotalInvestorPayout = 0;

        for (let i = 0; i < 30; i++) {
            let year = i + 1;

            // --- 1. CALCULATE DYNAMIC CASE ---
            let dynamicGrossRevenue = (currentPre * currentPreFee) + (currentAfter * currentAfterFee);
            let dynamicRoyalty = dynamicGrossRevenue * 0.10; // 10% ISLAPL Royalty Deduction
            let totalStudents = currentPre + currentAfter;
            let totalExpenses = currentFixedCost + (totalStudents * currentVarCost);
            
            // PBT is Revenue - 10% Royalty - Expenses
            let pbt = (dynamicGrossRevenue - dynamicRoyalty) - totalExpenses; 
            
            // Investor Math: Investors get exactly 1% of PBT per share
            let shareProfit = pbt * (1 / TOTAL_SHARES);
            let investorPayout = Math.max(MINIMUM_GUARANTEE_PAYOUT, shareProfit);

            cumulativeCashFlow += pbt;
            totalNetProfit += pbt;
            cashFlows.push(pbt);
            
            totalInvestorPayout += investorPayout;
            investorCashFlows.push(investorPayout);

            if (cumulativeCashFlow >= 0 && paybackYear === null) paybackYear = year;
            if (totalInvestorPayout >= PRICE_PER_SHARE && investorPaybackYear === null) investorPaybackYear = year;

            // --- 2. CALCULATE BASE CASE ---
            let bPre = baseCaseData[i]?.preStudents || 0;
            let bAfter = baseCaseData[i]?.afterStudents || 0;
            let bExp = baseCaseData[i]?.baseExpenses || 0;
            
            let bPreFee = inputs.preSchoolFee * Math.pow(1 + inputs.feeGrowth / 100, i);
            let bAfterFee = inputs.afterSchoolFee * Math.pow(1 + inputs.feeGrowth / 100, i);
            let bGrossRev = (bPre * bPreFee) + (bAfter * bAfterFee);
            
            let bRoyalty = bGrossRev * 0.10; // 10% Pass-through
            let bPbt = (bGrossRev - bRoyalty) - bExp;
            
            let bShareProfit = bPbt * (1 / TOTAL_SHARES);
            let bInvestorPayout = Math.max(MINIMUM_GUARANTEE_PAYOUT, bShareProfit);

            bCumulativeCashFlow += bPbt;
            bTotalNetProfit += bPbt;
            bCashFlows.push(bPbt);
            bTotalInvestorPayout += bInvestorPayout;
            bInvestorCashFlows.push(bInvestorPayout);

            if (bCumulativeCashFlow >= 0 && bPaybackYear === null) bPaybackYear = year;
            if (bTotalInvestorPayout >= PRICE_PER_SHARE && bInvestorPaybackYear === null) bInvestorPaybackYear = year;

            projectionData.push({
                year: `Yr ${year}`,
                yearNum: year,
                students: Math.round(totalStudents),
                revenue: Math.round(dynamicGrossRevenue),
                expenses: Math.round(totalExpenses),
                cumulative: Math.round(cumulativeCashFlow),
                
                baseStudents: Math.round(bPre + bAfter),
                baseRevenue: Math.round(bGrossRev),
                baseExpenses: Math.round(bExp),
                baseCumulative: Math.round(bCumulativeCashFlow)
            });

            // --- GROW DYNAMIC PARAMETERS FOR NEXT YEAR ---
            let growthFactor = 1 + inputs.studentGrowth / 100;
            currentPre *= growthFactor;
            currentAfter *= growthFactor;
            
            if (currentPre + currentAfter > inputs.maxCapacity) {
                let ratio = inputs.maxCapacity / (currentPre + currentAfter);
                currentPre *= ratio;
                currentAfter *= ratio;
            }
            
            currentPreFee *= (1 + inputs.feeGrowth / 100);
            currentAfterFee *= (1 + inputs.feeGrowth / 100);
            currentFixedCost *= (1 + inputs.expenseGrowth / 100);
            currentVarCost *= (1 + inputs.expenseGrowth / 100);
        }

        // Discounted Cash Flow Calculations
        let npv = 0, shareNpv = 0;
        let bNpv = 0, bShareNpv = 0;
        for (let t = 0; t < cashFlows.length; t++) {
            npv += cashFlows[t] / Math.pow(1 + inputs.discountRate / 100, t);
            shareNpv += investorCashFlows[t] / Math.pow(1 + inputs.discountRate / 100, t);
            bNpv += bCashFlows[t] / Math.pow(1 + inputs.discountRate / 100, t);
            bShareNpv += bInvestorCashFlows[t] / Math.pow(1 + inputs.discountRate / 100, t);
        }
        
        // Investor Pitch Window Stats
        let pitchCashFlows = investorCashFlows.slice(0, investorYear + 1);
        let pitchCumPayout = pitchCashFlows.slice(1).reduce((a, b) => a + b, 0);
        let pitchIrr = calculateIRR(pitchCashFlows);

        let bPitchCashFlows = bInvestorCashFlows.slice(0, investorYear + 1);
        let bPitchCumPayout = bPitchCashFlows.slice(1).reduce((a, b) => a + b, 0);
        let bPitchIrr = calculateIRR(bPitchCashFlows);

        const data = { 
            combinedData: projectionData, 
            dynamicKpis: { 
                npv, shareNpv,
                irr: calculateIRR(cashFlows), shareIrr: calculateIRR(investorCashFlows),
                moic: totalNetProfit / FIXED_CAPEX,
                shareMoic: totalInvestorPayout / PRICE_PER_SHARE,
                roi: ((totalNetProfit - FIXED_CAPEX) / FIXED_CAPEX) * 100, 
                shareRoi: ((totalInvestorPayout - PRICE_PER_SHARE) / PRICE_PER_SHARE) * 100,
                avgYield: ((totalNetProfit / 30) / FIXED_CAPEX) * 100,
                shareAvgYield: ((totalInvestorPayout / 30) / PRICE_PER_SHARE) * 100,
                paybackYear: paybackYear || '30+', sharePaybackYear: investorPaybackYear || '30+'
            },
            baseKpis: {
                npv: bNpv, shareNpv: bShareNpv,
                irr: calculateIRR(bCashFlows), shareIrr: calculateIRR(bInvestorCashFlows),
                moic: bTotalNetProfit / FIXED_CAPEX,
                shareMoic: bTotalInvestorPayout / PRICE_PER_SHARE,
                roi: ((bTotalNetProfit - FIXED_CAPEX) / FIXED_CAPEX) * 100, 
                shareRoi: ((bTotalInvestorPayout - PRICE_PER_SHARE) / PRICE_PER_SHARE) * 100,
                avgYield: ((bTotalNetProfit / 30) / FIXED_CAPEX) * 100,
                shareAvgYield: ((bTotalInvestorPayout / 30) / PRICE_PER_SHARE) * 100,
                paybackYear: bPaybackYear || '30+', sharePaybackYear: bInvestorPaybackYear || '30+'
            },
            investorPitchStats: { 
                yearPayout: investorCashFlows[investorYear], 
                cumulativePayout: pitchCumPayout, 
                irr: pitchIrr,
                baseYearPayout: bInvestorCashFlows[investorYear],
                baseCumulativePayout: bPitchCumPayout,
                baseIrr: bPitchIrr
            }
        };
        
        // Update DOM KPIs
        document.getElementById('kpi_npv').innerText = formatCurr(data.dynamicKpis.npv);
        document.getElementById('kpi_base_npv').innerText = `Base: ${formatCurr(data.baseKpis.npv)}`;
        document.getElementById('kpi_share_npv').innerText = formatCurr(data.dynamicKpis.shareNpv);
        document.getElementById('kpi_base_share_npv').innerText = `Base: ${formatCurr(data.baseKpis.shareNpv)}`;

        document.getElementById('kpi_irr').innerText = formatIrrTxt(data.dynamicKpis.irr);
        document.getElementById('kpi_base_irr').innerText = `Base: ${formatIrrTxt(data.baseKpis.irr)}`;
        document.getElementById('kpi_share_irr').innerText = formatIrrTxt(data.dynamicKpis.shareIrr);
        document.getElementById('kpi_base_share_irr').innerText = `Base: ${formatIrrTxt(data.baseKpis.shareIrr)}`;

        document.getElementById('kpi_moic').innerText = formatMoic(data.dynamicKpis.moic);
        document.getElementById('kpi_base_moic').innerText = `Base: ${formatMoic(data.baseKpis.moic)}`;
        document.getElementById('kpi_share_moic').innerText = formatMoic(data.dynamicKpis.shareMoic);
        document.getElementById('kpi_base_share_moic').innerText = `Base: ${formatMoic(data.baseKpis.shareMoic)}`;

        document.getElementById('kpi_roi').innerText = `${formatNum(data.dynamicKpis.roi)}%`;
        document.getElementById('kpi_base_roi').innerText = `Base: ${formatNum(data.baseKpis.roi)}%`;
        document.getElementById('kpi_share_roi').innerText = `${formatNum(data.dynamicKpis.shareRoi)}%`;
        document.getElementById('kpi_base_share_roi').innerText = `Base: ${formatNum(data.baseKpis.shareRoi)}%`;

        document.getElementById('kpi_yield').innerText = `${formatNum(data.dynamicKpis.avgYield)}%`;
        document.getElementById('kpi_base_yield').innerText = `Base: ${formatNum(data.baseKpis.avgYield)}%`;
        document.getElementById('kpi_share_yield').innerText = `${formatNum(data.dynamicKpis.shareAvgYield)}%`;
        document.getElementById('kpi_base_share_yield').innerText = `Base: ${formatNum(data.baseKpis.shareAvgYield)}%`;

        document.getElementById('kpi_payback').innerText = data.dynamicKpis.paybackYear === '30+' ? '30+ Yrs' : `Yr ${data.dynamicKpis.paybackYear}`;
        document.getElementById('kpi_base_payback').innerText = `Base: ${data.baseKpis.paybackYear === '30+' ? '30+ Yrs' : `Yr ${data.baseKpis.paybackYear}`}`;
        document.getElementById('kpi_share_payback').innerText = data.dynamicKpis.sharePaybackYear === '30+' ? '30+ Yrs' : `Yr ${data.dynamicKpis.sharePaybackYear}`;
        document.getElementById('kpi_base_share_payback').innerText = `Base: ${data.baseKpis.sharePaybackYear === '30+' ? '30+ Yrs' : `Yr ${data.baseKpis.sharePaybackYear}`}`;

        // Update Pitch Box
        document.getElementById('pitch_yr').innerText = investorYear;
        document.getElementById('pitch_yr2').innerText = investorYear;
        document.getElementById('pitch_div').innerText = formatCurr(data.investorPitchStats.yearPayout);
        document.getElementById('pitch_base_div').innerText = `Base: ${formatCurr(data.investorPitchStats.baseYearPayout)}`;
        document.getElementById('pitch_cum').innerText = formatCurr(data.investorPitchStats.cumulativePayout);
        document.getElementById('pitch_base_cum').innerText = `Base: ${formatCurr(data.investorPitchStats.baseCumulativePayout)}`;
        document.getElementById('pitch_irr').innerText = formatIrrTxt(data.investorPitchStats.irr);
        document.getElementById('pitch_base_irr').innerText = `Base: ${formatIrrTxt(data.investorPitchStats.baseIrr)}`;

        updateCharts(data.combinedData);
    }

    // --- CHART.JS INTEGRATION ---
