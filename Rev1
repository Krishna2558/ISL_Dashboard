            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { position: 'bottom', labels: { usePointStyle: true, boxWidth: 6 } },
                tooltip: {
                    backgroundColor: 'rgba(255, 255, 255, 0.95)', titleColor: '#1e293b', bodyColor: '#475569',
                    borderColor: '#e2e8f0', borderWidth: 1, padding: 10, boxPadding: 4,
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            if (label) label += ': ';
                            if (context.parsed.y !== null) {
                                if(context.chart.canvas.id === 'chart3') label += formatNum(context.parsed.y) + ' Students';
                                else label += formatCurr(context.parsed.y);
                            }
                            return label;
                        }
                    }
                }
            },
            scales: {
                x: { grid: { display: false, drawBorder: false }, ticks: { maxTicksLimit: 10, color: '#64748b', font: {size: 11} } },
                y: { border: { display: false }, grid: { color: '#f1f5f9', drawTicks: false }, ticks: { color: '#64748b', font: {size: 11} } }
            }
        };

        const ctx1 = document.getElementById('chart1').getContext('2d');
        chart1 = new Chart(ctx1, {
            type: 'bar', data: { datasets: [] },
            options: {
                ...commonOptions,
                scales: { ...commonOptions.scales, y: { ...commonOptions.scales.y, ticks: { ...commonOptions.scales.y.ticks, callback: val => '₹' + (val/10000000).toFixed(1) + 'Cr' } } }
            }
        });

        const ctx2 = document.getElementById('chart2').getContext('2d');
        chart2 = new Chart(ctx2, {
            type: 'line', data: { datasets: [] },
            options: {
                ...commonOptions,
                scales: { ...commonOptions.scales, y: { ...commonOptions.scales.y, ticks: { ...commonOptions.scales.y.ticks, callback: val => '₹' + (val/10000000).toFixed(1) + 'Cr' } } }
            }
        });

        const ctx3 = document.getElementById('chart3').getContext('2d');
        chart3 = new Chart(ctx3, {
            type: 'line', data: { datasets: [] },
            options: { ...commonOptions }
        });
    }

